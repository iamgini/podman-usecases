# Use Debian slim as base
FROM debian:bookworm-slim

# Install dependencies
RUN apt-get update && \
    apt-get install -y curl git ca-certificates build-essential && \
    rm -rf /var/lib/apt/lists/*

# Install Go
ENV GO_VERSION=1.21.2
RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz | tar -C /usr/local -xz

# Add Go to PATH
ENV PATH=$PATH:/usr/local/go/bin

# Install Hugo Extended
ENV HUGO_VERSION=0.148.2
RUN curl -fsSL https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_Linux-64bit.tar.gz | tar -C /usr/local/bin -xz

# Workdir
WORKDIR /site

# Default command
CMD ["hugo"]
